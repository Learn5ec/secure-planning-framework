{
  "framework": {
    "name": "secure-planning-framework",
    "version": "2.0.0",
    "status": "in-development",
    "schema_version": "2.0.0",
    "description": "Modular secure planning orchestration skill. Always-on: fires by default on every planning/development task; opt-out via explicit phrase. Converts feature ideas into enforceable security blueprints."
  },
  "compatibility": {
    "claude_code": "SKILL.md frontmatter (name + description) at root",
    "cursor": ".cursorrules (root, generated by build script)",
    "windsurf": ".windsurfrules (root, generated by build script)",
    "vscode_copilot": ".github/copilot-instructions.md (generated by build script)",
    "mcp": "planned",
    "npm": "npx spf",
    "cli": "./bin/spf.mjs"
  },
  "docs": {
    "location": "docs/",
    "contents": "Archive, peer-reviews, security-rules migration, planning documents"
  },
  "rule_packs": {
    "owasp_web": {
      "source": "OWASP Top 10:2025",
      "file": "knowledge/owasp/web_owasp_top10_2025.md",
      "version": "2025",
      "rule_prefix": "OWASP-"
    },
    "owasp_api": {
      "source": "OWASP API Top 10:2023",
      "file": "knowledge/api-top10/owasp_api_top10_2023.md",
      "version": "2023",
      "rule_prefix": "API-"
    },
    "mobile_masvs": {
      "source": "OWASP MASVS",
      "file": "knowledge/masvs/OWASP_MASVS.yaml",
      "version": "2.x",
      "rule_prefix": "MASVS-"
    },
    "ai_agentic": {
      "source": "OWASP Agentic AI Top 10",
      "file": "knowledge/ai/agentic_ai_rules_baseline.md",
      "version": "2026-draft",
      "rule_prefix": "ASI-"
    },
    "ai_llm_governance": {
      "source": "LLM/AI Security & Governance",
      "file": "knowledge/ai/llm_governance_rules_baseline.md",
      "version": "1.x",
      "rule_prefix": "LLM-GOV-"
    },
    "mcp": {
      "source": "MCP Secure Development",
      "file": "knowledge/ai/mcp_server_rules_baseline.md",
      "version": "1.0",
      "rule_prefix": "MCP-"
    },
    "compliance_dpdp": {
      "source": "DPDP Act 2023",
      "files": [
        "mappings/compliance/dpdp/dpdp_rules.md",
        "mappings/compliance/dpdp/dpdpa-compliance.md"
      ],
      "version": "2023",
      "rule_prefix": "DPDP-",
      "_disabled": true,
      "_reason": "DPDPA disabled pending org-wide implementation decision."
    },
    "common_baseline": {
      "source": "Internal secure engineering baseline",
      "file": "instructions/common_considerations.md",
      "version": "1.0",
      "rule_prefix": "COM-"
    },
    "cwe_mappings": {
      "source": "Curated CWE",
      "dir": "knowledge/cwe/",
      "version": "curated-1.0",
      "rule_prefix": "CWE-"
    }
  },
  "planned_compliance": [
    "DPDPA (re-enable when org decision made)",
    "GDPR",
    "EU_AI_Act",
    "HIPAA",
    "PCI_DSS",
    "SOC2",
    "ISO_27001"
  ],
  "versioning_policy": "Semantic versioning. Rule packs are versioned independently; the framework version pins a compatible set. Breaking rule-ID changes require a major bump."
}
